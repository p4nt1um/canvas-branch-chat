	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"esbuild": "0.17.3",
		"obsidian": "^1.7.2",
		"obsidian-typings": "^2.2.0",
		"tslib": "2.8.0",
		"typescript": "5.6.3"
	}
}
